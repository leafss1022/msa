  </CHANGES>

  <FILE Name="/boot/config/plugins/&name;/&packageFile;" Run="upgradepkg --install-new --reinstall">
    <URL>&packageURL;</URL>
    <SHA256>&packageSHA256;</SHA256>
  </FILE>

  <FILE Run="/bin/bash">
    <INLINE>
      <![CDATA[
set -e
mkdir -p /boot/config/plugins/msa
cfg="/boot/config/plugins/msa/msa.cfg"
if [ ! -f "$cfg" ]; then
  cat > "$cfg" <<'CFGEOF'
ENABLED="yes"
HOST="0.0.0.0"
PORT="7777"
DATA_DIR="/mnt/user/appdata/msa"
CFGEOF
fi
chmod 0755 /etc/rc.d/rc.msa 2>/dev/null || true
chmod 0755 /usr/local/emhttp/plugins/msa/event/started 2>/dev/null || true
chmod 0755 /usr/local/emhttp/plugins/msa/event/stopping_svcs 2>/dev/null || true
if grep -q '^ENABLED="yes"' "$cfg" && [ -x /etc/rc.d/rc.msa ]; then
  nohup /etc/rc.d/rc.msa start >/dev/null 2>&1 &
fi
      ]]>
    </INLINE>
  </FILE>

  <FILE Run="/bin/bash" Method="remove">
    <INLINE>
      <![CDATA[
set +e
if [ -x /etc/rc.d/rc.msa ]; then
  /etc/rc.d/rc.msa stop
fi
removepkg msa-0.4.2.0-x86_64-1
rm -f /boot/config/plugins/msa/msa-0.4.2.0-x86_64-1.txz
echo "msa plugin removed. Persistent data remains under /mnt/user/appdata/msa unless you delete it manually."
      ]]>
    </INLINE>
  </FILE>
</PLUGIN>
